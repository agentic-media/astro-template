# Per-site config consumed by the template. Copy to .env (or set in
# Cloudflare Pages → Settings → Environment variables) and uncomment
# the ones you need. Astro exposes any var prefixed with PUBLIC_ to
# the client bundle.

# --- Identity ---
# Display name (used in <title>, og:site_name)
# PUBLIC_SITE_NAME="Lorem Ipsum"
# Short name for PWA / apple-mobile-web-app-title (≤ 12 chars ideally)
# PUBLIC_SITE_SHORT_NAME="Lorem"
# Theme color for the address bar / PWA splash
# PUBLIC_THEME_COLOR="#0c1a3a"
# HTML lang attribute and og:locale
# PUBLIC_LANGUAGE="it"
# PUBLIC_OG_LOCALE="it_IT"

# --- Google Analytics 4 ---
# Empty / unset = GA script never loaded.
# PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- Google AdSense ---
# Both `ca-pub-XXXX` and bare `pub-XXXX` accepted; the template normalises.
# Empty / unset = adsbygoogle.js never loaded AND ads.txt returns empty.
# PUBLIC_ADSENSE_CLIENT="ca-pub-1234567890123456"
# Extra ads.txt lines (base64-encoded so multi-line content survives env-var
# storage). Decoded and appended after the AdSense line.
# PUBLIC_ADS_TXT_EXTRA="<base64>"

# --- CMP / cookie consent ---
# Provider: "consent.js" (default — the bundled JS banner) or "none".
# Other vendors (cookiebot, onetrust, …) can be wired by setting
# PUBLIC_CMP_PROVIDER=<vendor> and injecting their script in your
# per-site overrides; the template only ships consent.js.
# PUBLIC_CMP_PROVIDER="consent.js"
# PUBLIC_CMP_ID=""
# PUBLIC_CMP_COOKIE_NAME="site_consent"
# PUBLIC_CMP_STORAGE_KEY="site_consent"

# --- Web Push (per-site Cloudflare Worker) ---
# Set PUBLIC_PUSH_ENABLED=false to disable the opt-in UI even when
# VAPID is configured. PUBLIC_VAPID_KEY must be the public part of the
# VAPID keypair generated when you set up the worker; the private key
# stays as a Worker secret, never enters Pages env. PUBLIC_PUSH_API is
# the path on the same origin the Worker handles (default
# /api/push/subscribe → mapped via the route in workers/push/wrangler.toml).
# PUBLIC_PUSH_ENABLED="true"
# PUBLIC_VAPID_KEY=""
# PUBLIC_PUSH_API="/api/push/subscribe"

# --- robots.txt ---
# Comma-separated paths to disallow. Empty = "Allow: /" only.
# PUBLIC_ROBOTS_DISALLOW="/admin/,/draft/"
