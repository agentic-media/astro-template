# Per-site config consumed by the template. Astro exposes any var
# prefixed with PUBLIC_ to the client bundle.
#
# Set in Cloudflare Pages → Settings → Environment variables for the
# project (production AND preview), or in a local .env when running
# `astro dev`.

# --- Identity ---
# PUBLIC_SITE_NAME="Lorem Ipsum"
# PUBLIC_SITE_SHORT_NAME="Lorem"          # apple-mobile-web-app-title
# PUBLIC_SITE_URL="https://example.com"    # used by astro.config to set Astro.site
# PUBLIC_SITE_DESCRIPTION="Sed do eiusmod tempor incididunt."
# PUBLIC_THEME_COLOR="#0c1a3a"
# PUBLIC_LANGUAGE="it"
# PUBLIC_OG_LOCALE="it_IT"

# --- Homepage hero ---
# Empty values render no copy at all rather than a placeholder.
# PUBLIC_SITE_TAGLINE="Lorem ipsum"        # eyebrow above the headline
# PUBLIC_HOME_HEADLINE="Lorem ipsum"       # h1 (defaults to PUBLIC_SITE_NAME)
# PUBLIC_HOME_LEDE="Sed do eiusmod tempor."  # supporting paragraph (defaults to PUBLIC_SITE_DESCRIPTION)
# PUBLIC_HOME_EMPTY_TITLE="Nessun articolo ancora pubblicato."
# PUBLIC_HOME_EMPTY_BODY=""

# --- Topics taxonomy (drives nav, sidebar, /argomento, ArticleLayout label) ---
# JSON array of { slug, label, description?, icon? }.
# PUBLIC_SITE_TOPICS='[{"slug":"argomento-1","label":"Argomento 1","description":"…","icon":"📰"}]'
# PUBLIC_TOPICS_PAGE_TITLE="Argomenti"
# PUBLIC_TOPICS_PAGE_LEDE=""               # supporting copy on /argomento

# --- Footer ---
# Disclaimer is per-site. Template ships none. Wire your own copy:
# PUBLIC_FOOTER_DISCLAIMER="Lorem ipsum disclaimer."
# PUBLIC_COPYRIGHT_HOLDER="Lorem Ipsum SRL"  # defaults to PUBLIC_SITE_NAME
# PUBLIC_FOOTER_TOPICS_TITLE="Argomenti"
# PUBLIC_FOOTER_LINKS_TITLE="Collegamenti"
# Optional override of the footer link list:
# PUBLIC_SITE_FOOTER_LINKS='[{"href":"/","label":"Home"},{"href":"/chi-siamo/","label":"Chi siamo"}]'

# --- Contact ---
# PUBLIC_CONTACT_EMAIL="redazione@example.com"

# --- Google Analytics 4 ---
# Empty / unset = GA script never loaded.
# PUBLIC_GA_ID="G-XXXXXXXXXX"

# --- Google AdSense ---
# Empty / unset = adsbygoogle.js never loaded AND ads.txt returns empty.
# PUBLIC_ADSENSE_CLIENT="ca-pub-1234567890123456"
# PUBLIC_ADS_TXT_EXTRA="<base64>"

# --- CMP / cookie consent ---
# "consent.js" (default — bundled banner) or "none" or a vendor name
# you wire yourself.
# PUBLIC_CMP_PROVIDER="consent.js"
# PUBLIC_CMP_ID=""
# PUBLIC_CMP_COOKIE_NAME="site_consent"
# PUBLIC_CMP_STORAGE_KEY="site_consent"

# --- Web Push ---
# PUBLIC_PUSH_ENABLED="true"
# PUBLIC_VAPID_KEY=""
# PUBLIC_PUSH_API="/api/push/subscribe"

# --- robots.txt ---
# Comma-separated paths to disallow.
# PUBLIC_ROBOTS_DISALLOW=""
