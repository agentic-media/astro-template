---
import siteConfig from 'virtual:agentic-media/site-config';
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AuthorBox from '../components/AuthorBox.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Sidebar from '../components/Sidebar.astro';
import StickySidebar from '../components/StickySidebar.astro';
import Sources from '../components/Sources.astro';
import TagPill from '../components/TagPill.astro';
import { resolveTags } from '../lib/topics';
import sourcesCache from 'virtual:agentic-media/sources-cache';
import { getCollection } from 'astro:content';

export interface ArticleFrontmatter {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  publishedDate: string;
  modifiedDate?: string;
  author: string;
  authorSlug: string;
  tags: string[];
  topic: string;
  heroImage?: string;
  heroImageAlt?: string;
  sources?: { url: string; title?: string; siteName?: string }[];
  cited_sources?: {
    source_id: string;
    snippet?: string | null;
    position: number;
  }[];
  slug?: string;
  currentPage?: number;
  totalPages?: number;
  prevArticle?: { title: string; slug: string; topic: string } | null;
  nextArticle?: {
    title: string;
    slug: string;
    excerpt?: string;
    heroImage?: string;
    topic?: string;
  } | null;
}

export interface Props {
  article: ArticleFrontmatter;
  /** Pre-rendered HTML for the current page's body (markdown → HTML) */
  pageHtml: string;
}

const { article, pageHtml } = Astro.props;

const currentPage = article.currentPage ?? 1;
const totalPages = article.totalPages ?? 1;
const isFirstPage = currentPage === 1;
const isLastPage = currentPage === totalPages;
const hasMultiplePages = totalPages > 1;

const baseUrl = `/${article.topic}/${article.slug ?? ''}/`;
const pageUrl = (n: number) => (n === 1 ? baseUrl : `${baseUrl}${n}/`);

// Build topic-slug → display-label map from the per-site env JSON.
const topicLabels: Record<string, string> = Object.fromEntries(
  siteConfig.topics.map((t) => [t.slug, t.label])
);

const topicLabel = topicLabels[article.topic] ?? article.topic;

// Resolve tag slugs → {slug, label} for chip rendering.
// URLs still use slug; label comes from tag_vocabulary (falls back to slug).
const resolvedTags = resolveTags(article.tags, siteConfig.tag_vocabulary ?? []);

const authors = await getCollection('authors');
const authorData = authors.find(
  (a) => a.id === article.authorSlug || a.data.slug === article.authorSlug
);

function getInitials(name: string): string {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((n) => n[0]?.toUpperCase() ?? '')
    .join('');
}

function formatDate(dateStr: string) {
  return new Intl.DateTimeFormat('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(new Date(dateStr));
}

const authorInitials = getInitials(article.author);
const hasSources = (article.sources?.length ?? 0) > 0;
const hasCitedSources = (article.cited_sources?.length ?? 0) > 0;

// Sidebar data
const allArticles = await getCollection('articles');
const recentArticles = allArticles
  .sort(
    (a, b) =>
      new Date(b.data.publishedDate).getTime() -
      new Date(a.data.publishedDate).getTime()
  )
  .slice(0, 5)
  .map((a) => ({
    title: a.data.title,
    slug: a.id,
    image: a.data.heroImage,
    date: a.data.publishedDate,
    topic: a.data.topic,
  }));

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: topicLabel, href: `/argomento/${article.topic}/` },
  { label: article.title, href: '#' },
];

// Canonical URL: page 1 is the canonical for the whole article series;
// subsequent pages get rel="canonical" pointing to themselves but also
// rel="prev"/"next" so search engines understand the pagination.
const canonical = new URL(pageUrl(currentPage), Astro.site).toString();
const prevPageHref = !isFirstPage ? new URL(pageUrl(currentPage - 1), Astro.site).toString() : null;
const nextPageHref = !isLastPage ? new URL(pageUrl(currentPage + 1), Astro.site).toString() : null;

// JSON-LD citation block — emitted on the last page of paginated
// articles (where the sources block also renders). Primary path uses
// enriched cited_sources with snippets; fallback uses the flat sources
// array so articles that only have a sources: list still emit
// Article.citation for the SEO citation graph.
const citationCreativeWorks = (() => {
  if (!isLastPage) return undefined;
  if (hasCitedSources) {
    const ordered = [...article.cited_sources!].sort((a, b) => a.position - b.position);
    const works = ordered.flatMap((c) => {
      const cached = sourcesCache.bySourceId[c.source_id];
      if (!cached || cached.ok === false) return [];
      return [{
        '@type': 'CreativeWork' as const,
        url: cached.url,
        name: cached.title ?? cached.url,
        description: c.snippet ?? cached.description ?? undefined,
        publisher: cached.siteName
          ? { '@type': 'Organization' as const, name: cached.siteName }
          : undefined,
      }];
    });
    return works.length > 0 ? works : undefined;
  }
  // Fallback: emit from flat sources array when cited_sources is absent.
  if (hasSources) {
    const works = article.sources!.map((item) => ({
      '@type': 'CreativeWork' as const,
      url: item.url,
      name: item.title ?? item.url,
    }));
    return works.length > 0 ? works : undefined;
  }
  return undefined;
})();

const hasFaqs = (article.faqs?.length ?? 0) > 0;

// JSON-LD FAQPage schema — emitted on the last page only (where the
// FAQ block visibly renders) so paginated articles don't duplicate it
// across pages and so the schema mirrors what the reader sees.
const faqSchema = (isLastPage && hasFaqs)
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: article.faqs!.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    }
  : null;

// Derive human-readable topic display name.
// Prefer the per-site `topicDisplayNames` override map (set in
// site.config.yaml), then fall back to the existing `topicLabels` map
// built from `topics[].label`, and finally auto-derive from the slug
// (Title-Case with hyphens replaced by spaces).
function titleCase(slug: string): string {
  return slug
    .split('-')
    .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}
const topicDisplayName =
  siteConfig.topicDisplayNames?.[article.topic] ??
  topicLabel ??
  titleCase(article.topic);

const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? '';

// JSON-LD BreadcrumbList — emitted on every article page (all pages of
// paginated articles share the same breadcrumb structure).
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: `${siteOrigin}/`,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: topicDisplayName,
      item: `${siteOrigin}/argomento/${article.topic}/`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: article.title,
      item: canonical,
    },
  ],
};

// JSON-LD standalone WebPage entity — emitted on every article page.
// The `@id` matches the `mainEntityOfPage['@id']` inside the Article
// schema so search engines can resolve the cross-reference. `isPartOf`
// points to the site-level WebSite entity emitted on the homepage.
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': canonical,
  url: canonical,
  name: article.ogTitle ?? article.title,
  description: article.ogDescription ?? article.description,
  inLanguage: 'it-IT',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${siteOrigin}/#website`,
  },
};

// JSON-LD Article schema
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.description,
  image: article.heroImage ? new URL(article.heroImage, Astro.site).toString() : null,
  datePublished: article.publishedDate,
  dateModified: article.modifiedDate ?? article.publishedDate,
  author: {
    '@type': 'Person',
    name: article.author,
    url: new URL(`/autore/${article.authorSlug}/`, Astro.site).toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.identity.name,
    url: Astro.site?.toString() ?? '',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/logo.png', Astro.site).toString(),
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  isPartOf: hasMultiplePages
    ? {
        '@type': 'CreativeWork',
        name: article.title,
        url: new URL(baseUrl, Astro.site).toString(),
      }
    : undefined,
  citation: citationCreativeWorks,
};

// Title: append " — Pagina N" on subsequent pages so SERP shows the page
const pageTitle = isFirstPage
  ? article.ogTitle ?? article.title
  : `${article.ogTitle ?? article.title} — Pagina ${currentPage}`;

// Hero dims + derivatives come from site.config.yaml::media.hero (Phase 1).
// Render <picture>/<source srcset> when derivatives are configured; otherwise
// fall through to a single <img> (today's behaviour, byte-identical on sites
// that haven't opted in). See
// control-center/schemas/hero-dims-from-config.md §5.
const heroWidth = siteConfig.media.hero.width;
const heroHeight = siteConfig.media.hero.height;
const heroDerivatives = siteConfig.media.hero.derivatives;
const hasHeroDerivatives = article.heroImage != null && heroDerivatives.length > 0;
const heroDir = article.heroImage ? article.heroImage.replace(/\/[^/]+$/, '') : '';
const heroSrcset = hasHeroDerivatives
  ? [
      ...heroDerivatives
        .filter((w) => w < heroWidth)
        .map((w) => `${heroDir}/hero-${w}w.webp ${w}w`),
      `${article.heroImage} ${heroWidth}w`,
    ].join(', ')
  : '';
// Article column maxes out around 800px on wide screens; full-width below.
const heroSizes = '(min-width: 1024px) 800px, 100vw';
---

<Base
  title={pageTitle}
  description={article.ogDescription ?? article.description}
  canonicalUrl={canonical}
  ogImage={article.heroImage}
  heroImage={isFirstPage ? article.heroImage : undefined}
  publishedTime={article.publishedDate}
  modifiedTime={article.modifiedDate}
  authorName={article.author}
  type="article"
  prevPageHref={prevPageHref}
  nextPageHref={nextPageHref}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <Header />

  <div class="ist-container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <main>
    <div class="ist-container">
      <div class="ist-article-cols">
        <article class="ist-single" itemscope itemtype="https://schema.org/Article">
          {isFirstPage ? (
            <header class="ist-single__cover">
              {article.heroImage ? (
                hasHeroDerivatives ? (
                  <picture>
                    <source type="image/webp" srcset={heroSrcset} sizes={heroSizes} />
                    <img
                      class="ist-single__hero"
                      src={article.heroImage}
                      alt={article.heroImageAlt ?? article.title}
                      width={heroWidth}
                      height={heroHeight}
                      loading="eager"
                      fetchpriority="high"
                      decoding="async"
                      itemprop="image"
                    />
                  </picture>
                ) : (
                  <img
                    class="ist-single__hero"
                    src={article.heroImage}
                    alt={article.heroImageAlt ?? article.title}
                    width={heroWidth}
                    height={heroHeight}
                    loading="eager"
                    fetchpriority="high"
                    decoding="async"
                    itemprop="image"
                  />
                )
              ) : (
                <div class="ist-single__hero ist-single__hero--empty" aria-hidden="true">🌿</div>
              )}

              <div class="ist-single__cover-body">
                <a class="ist-single__topic" href={`/argomento/${article.topic}/`}>
                  {topicLabel}
                </a>

                <h1 class="ist-single__title" itemprop="headline">
                  {article.title}
                </h1>

                <p class="ist-single__excerpt" itemprop="description">
                  {article.description}
                </p>

                <div class="ist-single__meta">
                  {authorData?.data.avatar ? (
                    <img
                      class="ist-single__avatar"
                      src={authorData.data.avatar}
                      alt={`Foto di ${article.author}`}
                      width="40"
                      height="40"
                    />
                  ) : (
                    <span class="ist-single__avatar ist-single__avatar--initials" aria-hidden="true">
                      {authorInitials}
                    </span>
                  )}
                  <div class="ist-single__meta-text">
                    <a class="ist-single__author" href={`/autore/${article.authorSlug}/`}>
                      {article.author}
                    </a>
                    <time
                      class="ist-single__date"
                      datetime={article.publishedDate}
                      itemprop="datePublished"
                    >
                      {formatDate(article.publishedDate)}
                    </time>
                  </div>
                </div>

                {resolvedTags.length > 0 && (
                  <div class="ist-single__tags">
                    {resolvedTags.map((tag) => (
                      <TagPill tag={tag} topic={article.topic} />
                    ))}
                  </div>
                )}
              </div>
            </header>
          ) : (
            <header class="ist-single__cover ist-single__cover--slim">
              <div class="ist-single__slim-meta">
                <a class="ist-single__topic" href={`/argomento/${article.topic}/`}>
                  {topicLabel}
                </a>
                <span class="ist-single__page-counter">Pagina {currentPage} di {totalPages}</span>
              </div>
              <h1 class="ist-single__title-slim" itemprop="headline">
                <a href={pageUrl(1)}>{article.title}</a>
              </h1>
            </header>
          )}

          <!-- Top in-content ad slot. AdSense Auto Ads will fill, or
               we can place an explicit <ins class="adsbygoogle"> here. -->
          <div class="ist-ad-slot ist-ad-slot--top" data-ad-position="top" aria-hidden="true"></div>

          <div
            class="ist-single__body"
            itemprop="articleBody"
            set:html={pageHtml}
          />

          <!-- Mid in-content ad slot, just below the body and above
               the page nav / sources. -->
          <div class="ist-ad-slot ist-ad-slot--mid" data-ad-position="mid" aria-hidden="true"></div>

          {hasMultiplePages && (
            <nav class="ist-page-nav" aria-label="Paginazione articolo">
              {!isLastPage ? (
                <a class="ist-page-nav__cta" href={pageUrl(currentPage + 1)} rel="next">
                  <span class="ist-page-nav__cta-label">Continua a leggere</span>
                  <span class="ist-page-nav__cta-detail">
                    Pagina {currentPage + 1} di {totalPages}
                  </span>
                  <span class="ist-page-nav__cta-arrow" aria-hidden="true">→</span>
                </a>
              ) : (
                <p class="ist-page-nav__finished">
                  <span class="ist-page-nav__finished-mark" aria-hidden="true">✓</span>
                  Fine dell'articolo · {totalPages} pagine
                </p>
              )}

              <div class="ist-page-nav__row">
                {!isFirstPage ? (
                  <a class="ist-page-nav__prev" href={pageUrl(currentPage - 1)} rel="prev">
                    ← Pagina precedente
                  </a>
                ) : (
                  <span />
                )}

                <ol class="ist-page-nav__pages">
                  {Array.from({ length: totalPages }, (_, i) => i + 1).map((n) => (
                    n === currentPage ? (
                      <li class="ist-page-nav__page is-current" aria-current="page">{n}</li>
                    ) : (
                      <li><a class="ist-page-nav__page" href={pageUrl(n)}>{n}</a></li>
                    )
                  ))}
                </ol>

                {!isLastPage ? (
                  <a class="ist-page-nav__next-text" href={pageUrl(currentPage + 1)} rel="next">
                    Pagina successiva →
                  </a>
                ) : (
                  <span />
                )}
              </div>
            </nav>
          )}

          {isLastPage && siteConfig.integrations.push.enabled && siteConfig.integrations.push.vapidPublicKey && (
            <div class="ist-push-cta" data-no-scroll-snap>
              <div class="ist-push-cta__text">
                <p class="ist-push-cta__label">Resta aggiornato</p>
                <p class="ist-push-cta__title">Ricevi un avviso quando esce un nuovo articolo.</p>
              </div>
              <button type="button" class="ist-push-cta__btn" data-ist-push-open>
                Iscriviti agli aggiornamenti
              </button>
            </div>
          )}

          {isLastPage && hasFaqs && (
            <section class="ist-faqs" aria-labelledby="ist-faqs-heading">
              <h2 id="ist-faqs-heading" class="ist-faqs__heading">Domande frequenti</h2>
              <dl class="ist-faqs__list">
                {article.faqs!.map(({ q, a }) => (
                  <div class="ist-faqs__item">
                    <dt class="ist-faqs__question">{q}</dt>
                    <dd class="ist-faqs__answer">{a}</dd>
                  </div>
                ))}
              </dl>
            </section>
          )}

          {isLastPage && (hasSources || hasCitedSources) && (
            <Sources
              items={article.sources ?? []}
              cited_sources={article.cited_sources}
            />
          )}

          {isLastPage && authorData && (
            <AuthorBox
              name={authorData.data.name}
              bio={authorData.data.bio ?? authorData.data.bioShort}
              slug={authorData.data.slug}
              avatar={authorData.data.avatar}
              jobTitle={authorData.data.title}
            />
          )}

          <!-- Bottom ad slot, just before related navigation. -->
          <div class="ist-ad-slot ist-ad-slot--bottom" data-ad-position="bottom" aria-hidden="true"></div>

          {isLastPage && (article.prevArticle || article.nextArticle) && (
            <nav class="ist-post-nav" aria-label="Navigazione articoli">
              {article.prevArticle ? (
                <a class="ist-post-nav__item ist-post-nav__item--prev" href={`/${article.prevArticle.topic}/${article.prevArticle.slug}/`}>
                  <span class="ist-post-nav__label">← Articolo precedente</span>
                  <span class="ist-post-nav__title">{article.prevArticle.title}</span>
                </a>
              ) : (
                <div />
              )}
              {article.nextArticle && (
                <a class="ist-post-nav__item ist-post-nav__item--next" href={`/${article.nextArticle.topic}/${article.nextArticle.slug}/`}>
                  <span class="ist-post-nav__label">Articolo successivo →</span>
                  <span class="ist-post-nav__title">{article.nextArticle.title}</span>
                </a>
              )}
            </nav>
          )}
        </article>

        <StickySidebar class="ist-article-cols__sidebar" aria-label="Barra laterale">
          <Sidebar recentArticles={recentArticles} activeTopic={article.topic} />
        </StickySidebar>
      </div>
    </div>
  </main>

  <Footer />
</Base>
