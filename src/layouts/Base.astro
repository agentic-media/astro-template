---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  publishedTime?: string;
  modifiedTime?: string;
  authorName?: string;
  type?: 'website' | 'article';
  /** Optional class added to <body>. Used to scope mobile-fullscreen reader. */
  bodyClass?: string;
  /** Pagination relationships for multi-page articles */
  prevPageHref?: string | null;
  nextPageHref?: string | null;
  /** When true, emit `<meta name="robots" content="noindex, nofollow">`. Use for 404, draft previews, internal-only pages. */
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  ogImage = '/og-default.jpg',
  publishedTime,
  modifiedTime,
  authorName,
  type = 'website',
  bodyClass,
  prevPageHref,
  nextPageHref,
  noindex = false,
} = Astro.props;

// Per-site config — all read at build time from Cloudflare Pages env
// vars (PUBLIC_* names so Astro exposes them to client-side code where
// needed). Sensible defaults so a fresh consumer site builds even
// without setting any of them.
//
// Set in `domains/<slug>.yaml::cloudflare.pages_env` and project them
// into the CF Pages project's environment variables (production +
// preview). See template README for the full list and what each one
// gates.
const cfg = {
  siteName:           import.meta.env.PUBLIC_SITE_NAME           ?? 'Site',
  siteShortName:      import.meta.env.PUBLIC_SITE_SHORT_NAME     ?? import.meta.env.PUBLIC_SITE_NAME ?? 'Site',
  themeColor:         import.meta.env.PUBLIC_THEME_COLOR         ?? '#0c1a3a',
  language:           import.meta.env.PUBLIC_LANGUAGE            ?? 'it',
  ogLocale:           import.meta.env.PUBLIC_OG_LOCALE           ?? 'it_IT',

  // Google services — empty string disables the script entirely.
  gaId:               import.meta.env.PUBLIC_GA_ID               ?? '',
  adsenseClient:      import.meta.env.PUBLIC_ADSENSE_CLIENT      ?? '',

  // CMP / cookie banner. The bundled /consent.js is the default; set
  // PUBLIC_CMP_PROVIDER to 'none' to disable, 'cookiebot' to load
  // Cookiebot, etc. PUBLIC_CMP_ID is the provider's site/account id.
  cmpProvider:        import.meta.env.PUBLIC_CMP_PROVIDER        ?? 'consent.js',
  cmpId:              import.meta.env.PUBLIC_CMP_ID              ?? '',
  cmpCookieName:      import.meta.env.PUBLIC_CMP_COOKIE_NAME     ?? 'site_consent',
  cmpStorageKey:      import.meta.env.PUBLIC_CMP_STORAGE_KEY     ?? 'site_consent',

  // Push notifications.
  pushEnabled:       (import.meta.env.PUBLIC_PUSH_ENABLED       ?? 'true').toLowerCase() === 'true',
  vapidPublicKey:     import.meta.env.PUBLIC_VAPID_KEY           ?? '',
  pushApi:            import.meta.env.PUBLIC_PUSH_API            ?? '/api/push/subscribe',
};

const canonical = canonicalUrl ?? Astro.url.href;
const fullTitle = title === cfg.siteName ? title : `${title} — ${cfg.siteName}`;

const pushConfig = cfg.pushEnabled && cfg.vapidPublicKey
  ? { vapidPublicKey: cfg.vapidPublicKey, pushApi: cfg.pushApi }
  : null;

const consentConfig = cfg.cmpProvider === 'consent.js'
  ? {
      version: 1,
      cookieName: cfg.cmpCookieName,
      storageKey: cfg.cmpStorageKey,
      policyUrl: '/cookie-policy/',
      privacyUrl: '/privacy-policy/',
      categories: {
        necessary: {
          required: true,
          label: 'Necessari',
          description: 'Indispensabili per il funzionamento del sito. Non raccolgono dati personali e non richiedono consenso.',
        },
        preferences: {
          required: false,
          label: 'Preferenze',
          description: 'Memorizzano preferenze e abilitano contenuti incorporati da terze parti (es. video YouTube, Google Maps).',
        },
        analytics: {
          required: false,
          label: 'Analitici',
          description: 'Misurano traffico e comportamento degli utenti tramite Google Analytics 4.',
        },
        marketing: {
          required: false,
          label: 'Marketing',
          description: 'Attivano pubblicità personalizzata e remarketing tramite Google Ads.',
        },
      },
      texts: {
        title: 'Preferenze privacy',
        description: 'Utilizziamo cookie o tecnologie simili per finalità tecniche e, con il tuo consenso, anche per finalità analitiche e di marketing. Puoi liberamente prestare, rifiutare o revocare il consenso in qualsiasi momento.',
        acceptAll: 'Accetta tutto',
        rejectAll: 'Rifiuta tutto',
        customize: 'Personalizza',
        save: 'Salva e chiudi',
        settings: 'Impostazioni cookie',
      },
    }
  : null;
---

<!doctype html>
<html lang={cfg.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary Meta -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />}
    {prevPageHref && <link rel="prev" href={prevPageHref} />}
    {nextPageHref && <link rel="next" href={nextPageHref} />}

    <!-- Font Preloads (Blinker is the template default; override per site
         by shipping your own /fonts/ and CSS @font-face rules). -->
    <link
      rel="preload"
      href="/fonts/blinker-700-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/blinker-600-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:locale" content={cfg.ogLocale} />
    <meta property="og:site_name" content={cfg.siteName} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {authorName && <meta property="article:author" content={authorName} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- PWA manifest (required by iOS Safari for Web Push) -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={cfg.themeColor} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content={cfg.siteShortName} />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {/* Google Consent Mode v2 — default-deny everything except security_storage.
        MUST run before any Google script loads. CMP JS re-issues an 'update'
        once the user makes a choice. Skip the default-deny block if there's
        no Google integration enabled (gaId AND adsenseClient both empty). */}
    {(cfg.gaId || cfg.adsenseClient) && (
      <script is:inline>
        {`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = window.gtag || gtag;
          gtag('consent', 'default', {
            ad_storage:              'denied',
            ad_user_data:            'denied',
            ad_personalization:      'denied',
            analytics_storage:       'denied',
            functionality_storage:   'denied',
            personalization_storage: 'denied',
            security_storage:        'granted',
          });
        `}
      </script>
    )}

    {/* Cookie consent — bundled JS-driven banner. Set
        PUBLIC_CMP_PROVIDER=none to skip; or =cookiebot etc. to load
        a different vendor (you'll need to inject their script
        elsewhere). */}
    {consentConfig && (
      <>
        <script is:inline define:vars={{ SITE_CONSENT_CONFIG: consentConfig }}>
          {`window.SITE_CONSENT_CONFIG = SITE_CONSENT_CONFIG;`}
        </script>
        <script src="/consent.js" defer></script>
      </>
    )}

    {/* Web Push opt-in. VAPID public key + push API URL come from
        PUBLIC_VAPID_KEY / PUBLIC_PUSH_API. Skipped entirely when
        PUBLIC_PUSH_ENABLED=false or PUBLIC_VAPID_KEY is empty. */}
    {pushConfig && (
      <>
        <script is:inline define:vars={{ SITE_PUSH_CONFIG: pushConfig }}>
          {`window.SITE_PUSH_CONFIG = SITE_PUSH_CONFIG;`}
        </script>
        <script src="/push.js" defer></script>
      </>
    )}

    {/* Google AdSense — auto-ads loader. Only injected when
        PUBLIC_ADSENSE_CLIENT is set. The site MUST also serve ads.txt
        listing the same client; the template's /ads.txt route handles
        that. */}
    {cfg.adsenseClient && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${cfg.adsenseClient}`}
        crossorigin="anonymous"
      ></script>
    )}

    {/* Google Analytics 4. Skipped if PUBLIC_GA_ID is empty. */}
    {cfg.gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${cfg.gaId}`}></script>
        <script is:inline define:vars={{ GA_ID: cfg.gaId }}>
          {`gtag('js', new Date()); gtag('config', GA_ID);`}
        </script>
      </>
    )}
    {type === 'website' && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: cfg.siteName,
        url: Astro.site?.toString() ?? '',
        inLanguage: cfg.ogLocale.replace('_', '-'),
        potentialAction: {
          '@type': 'SearchAction',
          target: {
            '@type': 'EntryPoint',
            urlTemplate: `${(Astro.site?.toString() ?? '').replace(/\/$/, '')}/cerca/?q={search_term_string}`,
          },
          'query-input': 'required name=search_term_string',
        },
      })} />
    )}
  </head>
  <body class={bodyClass}>
    <slot />
    <div id="site-consent-root"></div>
  </body>
</html>
