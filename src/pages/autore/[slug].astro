---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';

const ARTICLES_PER_PAGE = 12;

export async function getStaticPaths() {
  const authors = await getCollection('authors');
  return authors.map((author) => ({
    params: { slug: author.data.slug },
    props: { author },
  }));
}

const { author } = Astro.props;
const { data } = author;

// Get author's articles
const allArticles = await getCollection('articles');
const authorArticles = allArticles
  .filter((a) => a.data.authorSlug === data.slug)
  .sort(
    (a, b) =>
      new Date(b.data.publishedDate).getTime() -
      new Date(a.data.publishedDate).getTime()
  );

const totalPages = Math.ceil(authorArticles.length / ARTICLES_PER_PAGE);
const currentPage = 1;
const pageArticles = authorArticles.slice(0, ARTICLES_PER_PAGE);

const recentArticles = allArticles
  .sort(
    (a, b) =>
      new Date(b.data.publishedDate).getTime() -
      new Date(a.data.publishedDate).getTime()
  )
  .slice(0, 5)
  .map((a) => ({
    title: a.data.title,
    slug: a.id,
    image: a.data.heroImage,
    date: a.data.publishedDate,
    topic: a.data.topic,
  }));

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Autori', href: '/chi-siamo/' },
  { label: data.name, href: '#' },
];

function getInitials(name: string): string {
  return name
    .split(' ')
    .filter(Boolean)
    .slice(0, 2)
    .map((n) => n[0].toUpperCase())
    .join('');
}

// JSON-LD Person schema
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.name,
  jobTitle: data.title,
  description: data.bio,
  url: new URL(`/autore/${data.slug}/`, Astro.site).toString(),
  worksFor: {
    '@type': 'Organization',
    name: 'Insieme Salute Toscana',
    url: Astro.site?.toString() ?? '',
  },
};
---

<Base
  title={`${data.name} — Insieme Salute Toscana`}
  description={data.bioShort}
  canonicalUrl={new URL(`/autore/${data.slug}/`, Astro.site).toString()}
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <Header />

  <div class="ist-container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <main>
    <div class="ist-container" style="padding-bottom:60px;">
      <!-- Author header -->
      <div class="ist-author-header">
        <div class="ist-author-header__avatar">
          {data.avatar ? (
            <img
              src={data.avatar}
              alt={`Foto di ${data.name}`}
              width="100"
              height="100"
            />
          ) : (
            <div class="ist-author-header__avatar-initials">
              {getInitials(data.name)}
            </div>
          )}
        </div>

        <div>
          <h1 class="ist-author-header__name">{data.name}</h1>
          <p class="ist-author-header__job-title">{data.title}</p>
          <p class="ist-author-header__bio">{data.bio}</p>

          {data.specialization.length > 0 && (
            <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:16px;">
              {data.specialization.map((spec) => (
                <span style="background:var(--base); border:1px solid var(--hairline); border-radius:var(--radius-tag); padding:3px 12px; font-size:0.78rem; color:var(--contrast-2);">
                  {spec}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>

      <div class="ist-layout-2col">
        <!-- Author's articles -->
        <div>
          <h2 style="font-size:1.3rem; font-weight:700; color:var(--navy); margin-bottom:24px;">
            Articoli di {data.name}
            {authorArticles.length > 0 && (
              <span style="font-size:0.85rem; color:var(--contrast-2); font-weight:400; margin-left:8px;">
                ({authorArticles.length})
              </span>
            )}
          </h2>

          {pageArticles.length > 0 ? (
            <div class="ist-card-grid">
              {pageArticles.map((article) => (
                <ArticleCard
                  title={article.data.title}
                  slug={article.id}
                  excerpt={article.data.description}
                  image={article.data.heroImage}
                  date={article.data.publishedDate}
                  author={article.data.author}
                  authorSlug={article.data.authorSlug}
                  tags={article.data.tags}
                  topic={article.data.topic}
                />
              ))}
            </div>
          ) : (
            <div style="background:var(--base-2); border-radius:var(--radius-card); padding:36px; text-align:center; color:var(--contrast-2);">
              <p>Nessun articolo ancora pubblicato da questo autore.</p>
            </div>
          )}

          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            basePath={`/autore/${data.slug}/`}
          />
        </div>

        <!-- Sidebar -->
        <aside aria-label="Barra laterale">
          <Sidebar recentArticles={recentArticles} />
        </aside>
      </div>
    </div>
  </main>

  <Footer />
</Base>
