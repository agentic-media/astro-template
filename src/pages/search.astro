---
/**
 * Template search page — injected at the path defined by
 * `site.config.yaml::search.path` (default: `/search/`).
 *
 * Consumers never ship this file. They own the URL path and all UI
 * strings via `site.config.yaml::search`:
 *
 *   search:
 *     path:        "/cerca/"
 *     label:       "Cerca"
 *     placeholder: "Cerca articoli…"
 *     uiTranslations:
 *       placeholder:   "Cerca articoli…"
 *       zero_results:  'Nessun risultato per "[SEARCH_TERM]".'
 *       …
 *
 * The injectRoute call in integration.ts reads `siteConfig.search.path`
 * and injects this page at that pattern, so:
 *   - Italian site  →  /cerca/
 *   - English site  →  /search/
 *   - Any site      →  whatever path the YAML specifies
 */
import siteConfig from 'virtual:agentic-media/site-config';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const siteName       = siteConfig.identity.name;
const q              = Astro.url.searchParams.get('q') ?? '';
const searchLabel    = siteConfig.search.label;
const searchPath     = siteConfig.search.path;
const uiTranslations = siteConfig.search.uiTranslations;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: searchLabel, href: '#' },
];
---

<Base
  title={`${searchLabel} — ${siteName}`}
  description={`${searchLabel} — ${siteName}`}
  canonicalUrl={new URL(searchPath, Astro.site).toString()}
  noindex={true}
>
  <Header />

  <div class="ist-container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <main>
    <div class="ist-container ist-search-wrap">
      <h1 class="ist-search-heading">{searchLabel}</h1>

      <div
        id="ist-pagefind-ui"
        class="ist-pagefind-ui"
        data-initial-query={q}
        data-ui-translations={JSON.stringify(uiTranslations)}
      ></div>

      <p id="ist-pagefind-fallback" class="ist-search-fallback" hidden>
        Search index not available. Run
        <code>astro build &amp;&amp; pagefind --site dist</code> first.
      </p>
    </div>
  </main>

  <Footer />
</Base>

<style>
  .ist-search-wrap {
    padding-block: 40px 80px;
    max-width: 860px;
  }

  .ist-search-heading {
    font-size: var(--fs-h2);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--contrast);
    margin-block-end: 28px;
  }

  .ist-search-fallback {
    color: var(--contrast-2);
    padding-block: 24px;
  }

  /* ------------------------------------------------------------------
     Pagefind UI token overrides — map Pagefind's CSS custom properties
     to the site design-system tokens so results inherit the brand voice.
     See https://pagefind.app/docs/ui-usage/#customising-the-styles
     ------------------------------------------------------------------ */
  .ist-pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary:             var(--accent);
    --pagefind-ui-text:                var(--contrast);
    --pagefind-ui-background:          var(--base-3);
    --pagefind-ui-border:              var(--hairline);
    --pagefind-ui-tag:                 var(--base-2);
    --pagefind-ui-border-width:        1px;
    --pagefind-ui-border-radius:       var(--radius-cta, 6px);
    --pagefind-ui-image-border-radius: var(--radius-card, 8px);
    --pagefind-ui-font:                var(--font-body);
  }
</style>

<script is:inline type="module">
  // Must be is:inline + type="module":
  //   - is:inline prevents Vite bundling, which would choke on the
  //     /pagefind/pagefind-ui.js URL (a build-time-generated asset,
  //     not a source file Vite can resolve).
  //   - type="module" gives the script module semantics so top-level
  //     await is legal. Without it the browser parses a classic script
  //     and throws: "await is only valid in async functions and the
  //     top level bodies of modules".
  //   - define:vars must NOT be used: it also forces is:inline but emits
  //     the script wrapped in an IIFE, losing module semantics.
  //
  // Data bridging: server-rendered values are passed via data-* attrs on
  // the container div, then read here at runtime.
  const container = document.getElementById('ist-pagefind-ui');
  const initialQuery = container?.dataset.initialQuery ?? '';
  const uiTranslations = container?.dataset.uiTranslations
    ? JSON.parse(container.dataset.uiTranslations)
    : {};

  async function initPagefind() {
    const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
    const ui = new PagefindUI({
      element: '#ist-pagefind-ui',
      showImages: false,
      translations: Object.keys(uiTranslations).length > 0 ? uiTranslations : undefined,
    });
    const prefill = initialQuery || new URLSearchParams(location.search).get('q') || '';
    if (prefill) ui.triggerSearch(prefill);
  }
  try {
    await initPagefind();
  } catch {
    const fallback = document.getElementById('ist-pagefind-fallback');
    if (fallback) fallback.hidden = false;
  }
</script>
