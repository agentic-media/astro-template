---
import siteConfig from 'virtual:agentic-media/site-config';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const siteName = siteConfig.identity.name;
const q = Astro.url.searchParams.get('q') ?? '';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Cerca', href: '#' },
];
---

<Base
  title={`Cerca — ${siteName}`}
  description={`Cerca articoli su ${siteName}`}
  canonicalUrl={new URL('/cerca/', Astro.site).toString()}
  noindex={true}
>
  <Header />

  <div class="ist-container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <main>
    <div class="ist-container ist-cerca-wrap">
      <h1 class="ist-cerca-heading">Cerca</h1>

      <!-- Pagefind UI mounts here. The JS below initialises it and
           pre-fills the query from ?q= when the sidebar search form
           submits to this page. -->
      <div id="ist-pagefind-ui" class="ist-pagefind-ui"></div>

      <!-- Fallback shown only before the index is built (dev mode). -->
      <p id="ist-pagefind-fallback" class="ist-cerca-fallback" hidden>
        Indice di ricerca non disponibile. Esegui prima
        <code>astro build &amp;&amp; pagefind --site dist</code>.
      </p>
    </div>
  </main>

  <Footer />
</Base>

<style>
  .ist-cerca-wrap {
    padding-block: 40px 80px;
    max-width: 860px;
  }

  .ist-cerca-heading {
    font-size: var(--fs-h2);
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--contrast);
    margin-block-end: 28px;
  }

  .ist-cerca-fallback {
    color: var(--contrast-2);
    padding-block: 24px;
  }

  /* ------------------------------------------------------------------
     Pagefind UI token overrides — map Pagefind's CSS custom properties
     to the site design-system tokens so results inherit the brand voice.
     See https://pagefind.app/docs/ui-usage/#customising-the-styles
     ------------------------------------------------------------------ */
  .ist-pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary:        var(--accent);
    --pagefind-ui-text:           var(--contrast);
    --pagefind-ui-background:     var(--base-3);
    --pagefind-ui-border:         var(--hairline);
    --pagefind-ui-tag:            var(--base-2);
    --pagefind-ui-border-width:   1px;
    --pagefind-ui-border-radius:  var(--radius-cta, 6px);
    --pagefind-ui-image-border-radius: var(--radius-card, 8px);
    --pagefind-ui-font:           var(--font-body);
  }
</style>

<script define:vars={{ initialQuery: q }}>
  // Pagefind UI lazy-loads on first interaction. On this page we mount
  // it immediately and pre-fill from the ?q= param so the sidebar search
  // form works without any redirect tricks.
  async function initPagefind() {
    const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
    const ui = new PagefindUI({
      element: '#ist-pagefind-ui',
      showImages: false,
      translations: {
        placeholder:   'Cerca articoli…',
        zero_results:  'Nessun risultato per "[SEARCH_TERM]".',
        many_results:  '[COUNT] risultati per "[SEARCH_TERM]"',
        one_result:    '1 risultato per "[SEARCH_TERM]"',
        alt_search:    'Nessun risultato per "[SEARCH_TERM]". Prova con "[DIFFERENT_TERM]"?',
        search_label:  'Cerca in questo sito',
        filters_label: 'Filtri',
        clear_search:  'Cancella',
        load_more:     'Carica altri risultati',
        search_hint:   'Inizia a scrivere per cercare…',
      },
    });

    // Pre-fill from ?q= (sidebar form submission) or URL hash fallback.
    const prefill = initialQuery || new URLSearchParams(location.search).get('q') || '';
    if (prefill) {
      ui.triggerSearch(prefill);
    }
  }

  // Pagefind UI JS is only present after `astro build && pagefind --site dist`.
  // In dev (astro dev), gracefully show the fallback message.
  try {
    await initPagefind();
  } catch {
    const fallback = document.getElementById('ist-pagefind-fallback');
    if (fallback) {
      fallback.hidden = false;
    }
  }
</script>
