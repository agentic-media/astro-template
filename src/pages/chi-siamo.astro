---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';

// This is the template-default chi-siamo. It's a structural scaffold —
// breadcrumbs, page hero, team grid from the authors collection,
// editorial-values list — with placeholder Lorem-ipsum copy. Each
// consuming site SHOULD ship its own /src/pages/chi-siamo.astro to
// override this with site-specific copy. Astro project routes win
// over the integration's injected route.

const authors = await getCollection('authors');

function getInitials(name: string): string {
  return name
    .split(' ')
    .filter(Boolean)
    .slice(0, 2)
    .map((n) => n[0].toUpperCase())
    .join('');
}

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Chi siamo', href: '#' },
];
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Site';
---

<Base
  title={`Chi siamo — ${siteName}`}
  description={`Scopri il team di ${siteName}.`}
  canonicalUrl={new URL('/chi-siamo/', Astro.site).toString()}
>
  <Header />

  <div class="ist-container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <main>
    <div class="ist-container" style="padding-bottom:60px;">
      <div class="ist-page-hero">
        <h1 class="ist-page-hero__title">Chi siamo</h1>
        <p class="ist-page-hero__desc">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit.
          Override <code>src/pages/chi-siamo.astro</code> in your site
          repo to replace this scaffold with your real copy.
        </p>
      </div>

      <section style="background:var(--base-2); border-radius:var(--radius-card); padding:40px; margin-bottom:48px;">
        <h2 style="font-size:1.4rem; font-weight:700; color:var(--navy); margin-bottom:20px;">
          La nostra missione
        </h2>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">
          <p style="color:var(--contrast-2); line-height:1.7;">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do
            eiusmod tempor incididunt ut labore et dolore magna aliqua.
          </p>
          <p style="color:var(--contrast-2); line-height:1.7;">
            Ut enim ad minim veniam, quis nostrud exercitation ullamco
            laboris nisi ut aliquip ex ea commodo consequat.
          </p>
        </div>
      </section>

      {authors.length > 0 && (
        <section>
          <h2 style="font-size:1.4rem; font-weight:700; color:var(--navy); margin-bottom:32px;">
            Il nostro team
          </h2>

          <div class="ist-team-grid">
            {authors.map((author) => (
              <div class="ist-team-card">
                <div class="ist-team-card__avatar">
                  {author.data.avatar ? (
                    <img src={author.data.avatar} alt={`Foto di ${author.data.name}`} width="80" height="80" loading="lazy" />
                  ) : (
                    <div class="ist-team-card__avatar-initials">{getInitials(author.data.name)}</div>
                  )}
                </div>
                <h3 class="ist-team-card__name">
                  <a href={`/autore/${author.data.slug}/`}>{author.data.name}</a>
                </h3>
                <p class="ist-team-card__title">{author.data.title}</p>
                <p class="ist-team-card__bio">{author.data.bioShort}</p>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer />
</Base>

<style>
  @media (max-width: 640px) {
    section div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
