---
function readTopics(): Array<{ slug: string; label: string; description?: string }> {
  const raw = import.meta.env.PUBLIC_SITE_TOPICS;
  if (typeof raw === 'string' && raw.trim()) {
    try {
      const parsed = JSON.parse(raw);
      if (Array.isArray(parsed)) return parsed;
    } catch { /* fall through */ }
  }
  return [
    { slug: 'argomento-1', label: 'Argomento 1' },
    { slug: 'argomento-2', label: 'Argomento 2' },
    { slug: 'argomento-3', label: 'Argomento 3' },
  ];
}

const links = [
  { href: '/', label: 'Home' },
  { href: '/chi-siamo/', label: 'Chi siamo' },
  { href: '/contatti/', label: 'Contatti' },
  { href: '/privacy-policy/', label: 'Privacy Policy' },
  { href: '/cookie-policy/', label: 'Cookie Policy' },
  { href: '/feed.xml', label: 'RSS Feed' },
];

interface Props {
  logoTop?: string;
  logoMiddle?: string;
  logoBottom?: string;
  siteName?: string;
  siteDescription?: string;
  topics?: Array<{ slug: string; label: string; description?: string }>;
}
const {
  logoTop = 'BRAND',
  logoMiddle = '',
  logoBottom = 'TEMPLATE',
  siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'Site',
  siteDescription = import.meta.env.PUBLIC_SITE_DESCRIPTION ?? '',
  topics = readTopics(),
} = Astro.props as Props;
const currentYear = new Date().getFullYear();
---

<footer class="ist-footer">
  <div class="ist-container">
    <div class="ist-footer__grid">
      <!-- Brand column -->
      <div class="ist-footer__brand">
        <a href="/" class="ist-logo ist-footer__logo" aria-label={siteName}>
          <span class="ist-logo__top">{logoTop}</span>
          {logoMiddle && <span class="ist-logo__salute">{logoMiddle}</span>}
          <span class="ist-logo__bottom">{logoBottom}</span>
        </a>
        <p class="ist-footer__lede">
          {siteDescription}
        </p>
      </div>

      <!-- Topics column -->
      <div>
        <h3 class="ist-footer__col-title">Argomenti</h3>
        <nav class="ist-footer__links" aria-label="Argomenti">
          {topics.map((topic) => (
            <a href={`/argomento/${topic.slug}/`}>{topic.label}</a>
          ))}
        </nav>
      </div>

      <!-- Links column -->
      <div>
        <h3 class="ist-footer__col-title">Collegamenti</h3>
        <nav class="ist-footer__links" aria-label="Link utili">
          {links.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </div>
    </div>

    <!-- Bottom strip -->
    <div class="ist-footer__bottom">
      <span>
        &copy; {currentYear} {siteName}. Tutti i diritti riservati.
      </span>
      <span>
        I contenuti hanno scopo informativo e non sostituiscono il parere medico.
        <a href="/privacy-policy/">Privacy</a> ·
        <a href="/cookie-policy/">Cookie</a>
      </span>
    </div>
  </div>
</footer>
