---
import siteConfig from 'virtual:agentic-media/site-config';
import { getNonEmptyTopics } from '../lib/topics';
// Topic list drives the header nav and the Sidebar's "argomenti" panel.
// Each consumer site overrides via PUBLIC_SITE_TOPICS — a JSON array of
// `{slug,label}` (and optional `description`). Falls back to a small
// generic placeholder so a fresh site builds without configuring this.
const currentPath = Astro.url.pathname;
interface Props {
  logoTop?: string;
  logoMiddle?: string;
  logoBottom?: string;
  siteName?: string;
  /** Override the YAML-driven topic list for this render. */
  topics?: Array<{ slug: string; label: string; description?: string }>;
  /** Override the YAML-driven primary nav links. */
  nav?: Array<{ href: string; label: string }>;
  /** Label for the Argomenti dropdown trigger. */
  topicsLabel?: string;
}
// Default topic list = topics with ≥ 1 article. Empty topics never
// land in the dropdown, so a click never lands on a placeholder page.
const defaultTopics = await getNonEmptyTopics();
const {
  logoTop = siteConfig.logo.top,
  logoMiddle = siteConfig.logo.middle,
  logoBottom = siteConfig.logo.bottom,
  siteName = siteConfig.identity.name,
  topics = defaultTopics,
  nav = siteConfig.header.nav,
  topicsLabel = siteConfig.header.topicsLabel,
} = Astro.props as Props;

---

<header class="ist-header">
  <div class="ist-container">
    <div class="ist-header__inner">
      <!-- CSS Wordmark Logo -->
      <a href="/" class="ist-logo" aria-label={`${siteName} - Homepage`}>
        <span class="ist-logo__top">{logoTop}</span>
        {logoMiddle && <span class="ist-logo__salute">{logoMiddle}</span>}
        <span class="ist-logo__bottom">{logoBottom}</span>
      </a>

      <!-- Mobile nav toggle -->
      <button
        class="ist-nav-toggle"
        aria-expanded="false"
        aria-controls="main-nav"
        aria-label="Apri menu di navigazione"
        id="nav-toggle"
      >
        ☰
      </button>

      <!-- Navigation: nav links from YAML in declaration order; the
           Argomenti dropdown is appended at the end (the nav array
           shouldn't include /argomento/ — the dropdown is a separate
           UX element). -->
      <nav class="ist-nav" id="main-nav" aria-label="Navigazione principale">
        {nav.map((item) => {
          const isActive = item.href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(item.href.replace(/\/$/, ''));
          return (
            <a href={item.href} class={isActive ? 'active' : ''}>
              {item.label}
            </a>
          );
        })}

        {topics.length > 0 && (
          <div class="ist-nav__dropdown" id="argomenti-dropdown">
            <a
              href="/argomento/"
              class={`ist-nav__dropdown-toggle ${currentPath.startsWith('/argomento') ? 'active' : ''}`}
              aria-haspopup="true"
              aria-expanded="false"
            >
              {topicsLabel}
            </a>
            <ul class="ist-nav__dropdown-menu" role="menu">
              {topics.map((topic) => (
                <li role="none">
                  <a
                    href={`/argomento/${topic.slug}/`}
                    role="menuitem"
                    class={currentPath === `/argomento/${topic.slug}/` ? 'active' : ''}
                  >
                    {topic.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('main-nav');
  const dropdownBtn = document.querySelector('.ist-nav__dropdown-toggle') as HTMLElement | null;
  const dropdown = document.getElementById('argomenti-dropdown');

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const isOpen = nav.classList.toggle('is-open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      toggle.textContent = isOpen ? '✕' : '☰';
    });
  }

  // Mobile dropdown toggle
  if (dropdownBtn && dropdown) {
    dropdownBtn.addEventListener('click', (e) => {
      const isMobile = window.innerWidth < 768;
      if (isMobile) {
        e.preventDefault();
        const isOpen = dropdown.classList.toggle('is-open');
        dropdownBtn.setAttribute('aria-expanded', String(isOpen));
      }
    });
  }
</script>
