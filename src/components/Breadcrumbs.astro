---
export interface BreadcrumbItem {
  label: string;
  href: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

// Build JSON-LD BreadcrumbList schema. Skip entries without an href
// (commonly the current page, where consumers pass `{label: 'Foo'}`
// or `{label: 'Foo', href: '#'}` — the latter is correct, the former
// would crash without this guard).
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items
    .filter((item) => item.href && item.href !== '#')
    .map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      item: item.href.startsWith('http')
        ? item.href
        : new URL(item.href, Astro.site).toString(),
    })),
};
---

<nav class="ist-breadcrumb" aria-label="Percorso di navigazione">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <ol itemscope itemtype="https://schema.org/BreadcrumbList">
    {items.map((item, index) => {
      const isLast = index === items.length - 1;
      return (
        <li
          itemprop="itemListElement"
          itemscope
          itemtype="https://schema.org/ListItem"
        >
          {isLast ? (
            <span aria-current="page" itemprop="name">
              {item.label.length > 60 ? item.label.slice(0, 57) + '…' : item.label}
            </span>
          ) : (
            <a href={item.href} itemprop="item">
              <span itemprop="name">{item.label}</span>
            </a>
          )}
          <meta itemprop="position" content={String(index + 1)} />
        </li>
      );
    })}
  </ol>
</nav>
